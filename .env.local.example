# Contact form email (Resend)
# Get your API key at https://resend.com — verify getvolley.com domain first
RESEND_API_KEY=re_your_key_here

# Vercel Analytics API (for Log Analysis Agent)
# Token: https://vercel.com/account/tokens
# Project ID: Vercel Dashboard → Project → Settings → General
VERCEL_TOKEN=your_vercel_token
VERCEL_PROJECT_ID=your_project_id
VERCEL_TEAM_ID=your_team_id_if_applicable

# Anthropic API (for Log Analysis Agent)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Local testing overrides (remove for production)
# EMAIL_FROM=onboarding@resend.dev
# EMAIL_TO=your_personal_email@gmail.com
